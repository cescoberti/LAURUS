# Supabase project (create at supabase.com, then Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-side only; used for admin invites, never exposed to the client

# Used to build the invite-email redirect link (http://localhost:3010 in dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3010

# Email of the first admin, used once by `npm run bootstrap-admin`
ADMIN_EMAIL=
